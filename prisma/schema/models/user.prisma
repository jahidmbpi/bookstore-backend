model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  name      String?
  role      Role       @default(USER)
  status    UserStatus @default(ACTIVE)
  isDeleted Boolean    @default(false)
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCK
}
