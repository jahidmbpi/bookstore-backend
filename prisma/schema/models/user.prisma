model User {
  id        String     @id @default(uuid())
  name      String?
  email     String     @unique
  password String
  phone String?
  role      Role       @default(ADMIN)
  status    UserStatus @default(ACTIVE)
  isDeleted Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}


